# ── Server ────────────────────────────────────────────────────────────────────
PORT=3200
NODE_ENV=production
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://worklog_user:changeme_in_production@localhost:5433/worklog_dashboard
POSTGRES_PASSWORD=changeme_in_production

# ── Hurma HR API ──────────────────────────────────────────────────────────────
# Base URL of your Hurma instance
HURMA_BASE_URL=https://bestwork.hurma.work

# Hurma OAuth Bearer token (same token used by the main HurmaRecorder service)
HURMA_API_TOKEN=your_hurma_api_token_here

# Hurma API version for HR/employee endpoints.
# v1 = HR module (employees, absences) — default
# v3 = ATS module (candidates — used by parent project)
# Verify at https://swagger-ui.hurma.work/ which version exposes /employees and /absences
HURMA_HR_API_VERSION=v1

# ── Redmine API ───────────────────────────────────────────────────────────────
REDMINE_BASE_URL=https://project.mirko.in.ua
REDMINE_API_KEY=xbQWWeN0JAcjyXInwSgg

# ── Dashboard Admin Auth (HTTP Basic Auth) ────────────────────────────────────
# These protect the entire dashboard. Change before going to production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_strong_password

# ── Business rules ────────────────────────────────────────────────────────────
# Default daily working hours (Ukraine standard = 8)
DEFAULT_WORK_HOURS_PER_DAY=8

# Hours delta within which status is considered OK (default ±0.5h)
OK_DELTA_THRESHOLD_HOURS=0.5

# Timezone used for date calculations
DEFAULT_TIMEZONE=Europe/Kiev
